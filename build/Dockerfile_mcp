FROM python:3.11-slim

WORKDIR /app

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy only what's needed for MCP server
COPY pyproject.toml uv.lock ./
COPY src/__init__.py src/__init__.py
COPY src/infrastructure/__init__.py src/infrastructure/__init__.py
COPY src/infrastructure/mcp/ src/infrastructure/mcp/
COPY src/infrastructure/config/ src/infrastructure/config/

# Install dependencies
RUN uv sync --frozen --no-dev --extra mcp --no-install-project

# Expose HTTP port
EXPOSE 8000

# Set Python path
ENV PYTHONPATH=/app/src

# Run MCP server
CMD [".venv/bin/fastmcp", "run", "infrastructure.mcp.server.server:mcp", "--transport", "http", "--host", "0.0.0.0", "--port", "8000"]
